rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isHouseholdOwner(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId))
        && get(/databases/$(database)/documents/households/$(householdId)).data.ownerId == request.auth.uid;
    }

    function isHouseholdMember(householdId) {
      return signedIn()
        && exists(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid));
    }

    function moduleAccess(householdId, moduleName) {
      return get(/databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid)).data.permissions[moduleName];
    }

    function canViewModule(householdId, moduleName) {
      return isHouseholdOwner(householdId)
        || (isHouseholdMember(householdId)
          && (moduleAccess(householdId, moduleName) == 'view'
            || moduleAccess(householdId, moduleName) == 'edit'));
    }

    function canEditModule(householdId, moduleName) {
      return isHouseholdOwner(householdId)
        || (isHouseholdMember(householdId)
          && moduleAccess(householdId, moduleName) == 'edit');
    }

    function hasMatchingInvite(householdId) {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/householdInvites/$(request.auth.token.email))
        && get(/databases/$(database)/documents/householdInvites/$(request.auth.token.email)).data.householdId == householdId;
    }

    function matchingInvite(householdId) {
      return get(/databases/$(database)/documents/householdInvites/$(request.auth.token.email)).data;
    }

    function validMonthlyPlan() {
      return request.resource.data.salary is number
        && request.resource.data.salary > 0
        && request.resource.data.categories is list;
    }

    function validTransaction() {
      return request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.amount is number
        && request.resource.data.amount > 0
        && request.resource.data.categoryId is string
        && request.resource.data.categoryId.size() > 0;
    }

    function validMarketBudget() {
      return request.resource.data.kind == 'budget'
        && request.resource.data.monthKey is string
        && request.resource.data.budget is number
        && request.resource.data.budget > 0;
    }

    function validMarketExpense() {
      return request.resource.data.kind == 'expense'
        && request.resource.data.monthKey is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
    }

    match /users/{userId} {
      allow create, read, update, delete: if isSelf(userId);

      match /promotionScenarios/{scenarioId} {
        allow read, write: if isSelf(userId);
      }

      match /investmentAccounts/{accountId} {
        allow read, write: if isSelf(userId);
      }

      match /financialGoals/{goalId} {
        allow read, write: if isSelf(userId);
      }

      match /monthlyPlans/{monthId} {
        allow read, delete: if isSelf(userId);
        allow create, update: if isSelf(userId) && validMonthlyPlan();

        match /transactions/{transactionId} {
          allow read, delete: if isSelf(userId);
          allow create, update: if isSelf(userId) && validTransaction();
        }
      }
    }

    match /households/{householdId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string;
      allow read: if isHouseholdOwner(householdId) || isHouseholdMember(householdId);
      allow update, delete: if isHouseholdOwner(householdId);

      match /members/{memberId} {
        allow read: if isHouseholdOwner(householdId) || isHouseholdMember(householdId);
        allow create: if isHouseholdOwner(householdId)
          || (memberId == request.auth.uid
            && hasMatchingInvite(householdId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.email == request.auth.token.email
            && request.resource.data.role == 'member'
            && request.resource.data.status == 'active'
            && request.resource.data.permissions == matchingInvite(householdId).permissions);
        allow update, delete: if isHouseholdOwner(householdId);
      }

      match /activity/{activityId} {
        allow read: if isHouseholdOwner(householdId) || isHouseholdMember(householdId);
        allow create: if (isHouseholdOwner(householdId) || isHouseholdMember(householdId))
          && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }

      match /marketItems/{itemId} {
        allow read: if canViewModule(householdId, 'market');
        allow create: if request.resource.data.addedBy == request.auth.uid
          && ((validMarketBudget() && isHouseholdOwner(householdId))
            || (validMarketExpense() && canEditModule(householdId, 'market')));
        allow update: if request.resource.data.addedBy == resource.data.addedBy
          && request.resource.data.kind == resource.data.kind
          && request.resource.data.monthKey == resource.data.monthKey
          && ((validMarketBudget() && isHouseholdOwner(householdId))
            || (validMarketExpense() && canEditModule(householdId, 'market')));
        allow delete: if (resource.data.kind == 'budget' && isHouseholdOwner(householdId))
          || (resource.data.kind == 'expense' && canEditModule(householdId, 'market'))
          || (!resource.data.keys().hasAny(['kind']) && canEditModule(householdId, 'market'));
      }

      match /wishes/{wishId} {
        allow read: if canViewModule(householdId, 'wishes');
        allow create: if canEditModule(householdId, 'wishes')
          && request.resource.data.ownerId == request.auth.uid;
        allow update: if canEditModule(householdId, 'wishes')
          && request.resource.data.ownerId == resource.data.ownerId;
        allow delete: if canEditModule(householdId, 'wishes');
      }
    }

    match /householdInvites/{inviteEmail} {
      allow create: if signedIn()
        && request.resource.data.email == inviteEmail
        && request.resource.data.invitedBy == request.auth.uid
        && isHouseholdOwner(request.resource.data.householdId);
      allow get: if signedIn()
        && (request.auth.token.email == inviteEmail
          || isHouseholdOwner(resource.data.householdId));
      allow list: if signedIn()
        && isHouseholdOwner(resource.data.householdId);
      allow update: if signedIn() && isHouseholdOwner(resource.data.householdId);
      allow delete: if signedIn()
        && (isHouseholdOwner(resource.data.householdId)
          || request.auth.token.email == inviteEmail);
    }
  }
}
